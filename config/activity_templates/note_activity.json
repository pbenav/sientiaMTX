{
    "type": "note",
    "display_name": "Nota",
    "description": "Actividad para gestionar notas y apuntes",
    "icon": "icon-note",
    "color": "#f1c40f",
    "properties": {
        "title": {
            "type": "string",
            "required": true,
            "max_length": 255,
            "searchable": true
        },
        "description": {
            "type": "text",
            "required": false,
            "max_length": 1000000,
            "searchable": true
        },
        "status": {
            "type": "string",
            "required": false,
            "default": "draft",
            "enum": [
                "draft",
                "final",
                "archived"
            ]
        }
    },
    "states": {
        "draft": {
            "transitions": [
                "final",
                "archived"
            ]
        },
        "final": {
            "transitions": [
                "draft",
                "archived"
            ]
        },
        "archived": {
            "transitions": [
                "draft"
            ]
        }
    },
    "conversions": {
        "allowed_targets": [
            "task",
            "document"
        ],
        "property_mapping": {
            "title": "title",
            "description": "description"
        },
        "preserve_metadata": [
            "tags",
            "assignments",
            "attachments"
        ]
    },
    "actions": {
        "create": true,
        "update": true,
        "delete": true,
        "convert": true,
        "archive": true,
        "assign": true,
        "rate": true
    }
}