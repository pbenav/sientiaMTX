{
    "type": "meeting",
    "display_name": "Reunión",
    "description": "Actividad para gestionar reuniones y convocatorias",
    "icon": "icon-meeting",
    "color": "#27ae60",
    "properties": {
        "title": {
            "type": "string",
            "required": true,
            "max_length": 255,
            "searchable": true
        },
        "description": {
            "type": "text",
            "required": false,
            "max_length": 1000000,
            "searchable": true
        },
        "location": {
            "type": "string",
            "required": false,
            "max_length": 255
        },
        "url": {
            "type": "string",
            "required": false,
            "max_length": 1000
        },
        "duration_minutes": {
            "type": "integer",
            "required": false,
            "default": 60
        },
        "status": {
            "type": "string",
            "required": false,
            "default": "scheduled",
            "enum": [
                "scheduled",
                "in_progress",
                "completed",
                "cancelled"
            ]
        }
    },
    "states": {
        "scheduled": {
            "transitions": [
                "in_progress",
                "cancelled"
            ]
        },
        "in_progress": {
            "transitions": [
                "completed",
                "cancelled"
            ]
        },
        "completed": {
            "transitions": []
        },
        "cancelled": {
            "transitions": [
                "scheduled"
            ]
        }
    },
    "conversions": {
        "allowed_targets": [
            "task",
            "decision"
        ],
        "property_mapping": {
            "title": "title",
            "description": "description",
            "scheduled_date": "scheduled_date"
        },
        "preserve_metadata": [
            "tags",
            "assignments",
            "attachments"
        ]
    },
    "actions": {
        "create": true,
        "update": true,
        "delete": true,
        "convert": true,
        "archive": true,
        "assign": true,
        "rate": true
    }
}